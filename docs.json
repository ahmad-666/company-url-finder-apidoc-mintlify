{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Company URL Finder",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "tabler"
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting started",
        "pages": [
          "/apis/quick-start",
          "/apis/authentication",
          "/apis/usage-limits",
          "/apis/errors"
        ]
      },
      {
        "group": "Documentations",
        "pages": [
          {
            "group": "APIs",
            "directory": "accordion",
            "root": "/apis",
            "pages": [
              "/apis/company-name-to-domain",
              "/apis/company-domain-to-name",
              "/apis/linkedin-company-url-finder"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "href": "/apis",
    "light": "/images/logos/logo-dark-text.png",
    "dark": "/images/logos/logo-white-text.png"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://companyurlfinder.com/login"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "youtube": "https://www.youtube.com/@CompanyURLFinder",
      "linkedin": "https://www.linkedin.com/company/companyurlfinder/"
    }
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/apis",
      "permanent": true
    }
  ]
}
